GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Gemini — primary key + up to 19 rotation keys
GEMINI_API_KEY=AIza...
GEMINI_API_KEY_1=AIza...
GEMINI_API_KEY_2=AIza...
# Pre-skip exhausted keys (comma-separated env var names, e.g. GEMINI_API_KEY_3)
# GEMINI_SKIP_KEYS=GEMINI_API_KEY_3
# Override default model (default: gemini-2.5-flash-lite)
# GEMINI_MODEL=gemini-2.0-flash

# Amplitude (optional — omit to disable tracking)
AMPLITUDE_API_KEY=your-amplitude-key
# App name shown in Amplitude user_id
LLM_APP_NAME=TravelAPP
